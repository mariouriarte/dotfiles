//
// Do any local configuration here
//

// Consider adding the 1918 zones here, if they are not used in your
// organization
//include "/etc/bind/zones.rfc1918";

zone "youtube.aula" {
        type master;
        file "/etc/bind/zonas/db.youtubeaula";
};

zone "blackcat" {
	type master;
	file "/etc/bind/zonas/db.blackcat";
};

zone "openelec" {
	type master;
	file "/etc/bind/zonas/db.openelec";
};
