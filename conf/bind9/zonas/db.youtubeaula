;
; BIND data file for local loopback interface
;
$TTL	604800
@	IN	SOA	debian8.youtube.aula. root.youtube.aula. (
			      3		; Serial
			 604800		; Refresh
			  86400		; Retry
			2419200		; Expire
			 604800 )	; Negative Cache TTL
;
@	IN	NS	debian8.youtube.aula.
@	IN	A	192.168.100.10
debian8	IN	A	192.168.100.10
aluno 	IN	A	192.168.100.10

