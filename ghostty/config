# --- Apariencia ---
theme = "Ayu"
background-opacity = 0.95
background-blur-radius = 0
window-decoration = true
window-padding-x = 10
window-padding-y = 10
window-padding-balance = true
window-theme = dark

window-height = 35
window-width = 140

# --- Tipografía ---
font-family = "MesloLGS Nerd Font Mono"
font-size = 11
font-feature = -liga
font-thicken = true
adjust-cell-height = 10%

# --- Cursor y Ratón ---
cursor-style = bar
cursor-style-blink = true
cursor-click-to-move = true
mouse-hide-while-typing = true
mouse-shift-capture = true

# --- Comportamiento de Ventana ---
# window-save-state = always
# window-step-resize = true
window-inherit-working-directory = true
confirm-close-surface = true
unfocused-split-opacity = 0.8

# --- Integración de Shell ---
term = xterm-256color
shell-integration = detect
copy-on-select = clipboard
clipboard-read = allow
clipboard-write = allow

# Navegación de divisiones (Splits)
keybind = alt+e=new_split:right
keybind = alt+o=new_split:down
keybind = alt+h=goto_split:left
keybind = alt+l=goto_split:right
keybind = alt+k=goto_split:top
keybind = alt+j=goto_split:bottom

# Utilidades
keybind = f11=toggle_fullscreen
# keybind = f12=inspector:toggle
